# Backend environment variables example
# Copy this file to `.env` and adjust the values as needed.

# CORS 允许的前端地址，多个用逗号分隔，开发阶段可直接使用 *
CORS_ALLOW_ORIGINS=http://localhost:5173

# 大模型 Provider 配置
# 可选：mock / doubao / openai / 其他自定义标识
LLM_PROVIDER=mock
# 当接入真实服务时填写对应的 API Key；保持为空则自动退回 mock 实现
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=

# 视觉理解 / OCR Provider
VISION_PROVIDER=mock
VISION_API_KEY=

# 文生图 Provider
T2I_PROVIDER=mock
T2I_API_KEY=
T2I_API_BASE=
T2I_MODEL=

# 对象存储 Provider（本地调试建议使用 mock，本地写入 backend/static）
STORAGE_PROVIDER=mock
STORAGE_API_KEY=
