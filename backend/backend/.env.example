# Backend environment variables example
# Copy this file to `.env` and adjust the values as needed.

# CORS 允许的前端地址，多个用逗号分隔，开发阶段可直接使用 *
CORS_ALLOW_ORIGINS=http://localhost:5173

# 大模型 Provider 配置
# 可选：mock / doubao / openai / 其他自定义标识
LLM_PROVIDER=mock
# 当接入真实服务时填写对应的 API Key；保持为空则自动退回 mock 实现
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=

# 视觉理解 / OCR Provider
VISION_PROVIDER=mock
VISION_API_KEY=

# 文生图 Provider
T2I_PROVIDER=mock
T2I_API_KEY=
T2I_API_BASE=
T2I_MODEL=

# 对象存储 Provider：local / aliyun / s3
STORAGE_PROVIDER=local
STORAGE_API_KEY=

# 阿里云 OSS（当 STORAGE_PROVIDER=aliyun 时）
# ALIYUN_OSS_ACCESS_KEY_ID=
# ALIYUN_OSS_ACCESS_KEY_SECRET=
# ALIYUN_OSS_BUCKET=
# ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# ALIYUN_OSS_PUBLIC_BASE_URL=https://你的bucket.oss-cn-hangzhou.aliyuncs.com

# S3 兼容对象存储（可选）
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_PUBLIC_BASE_URL=
